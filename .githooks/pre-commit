#!/usr/bin/env bash
# Roda o ESLint apenas nos arquivos TS/TSX em stage antes de cada commit.
# Impede que código com erros de lint entre no repositório (avisos não bloqueiam).

set -e

files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(ts|tsx)$' || true)
[ -z "$files" ] && exit 0

if [ ! -x ./node_modules/.bin/eslint ]; then
  echo "warn pre-commit: eslint não encontrado, pulando lint" >&2
  exit 0
fi

# shellcheck disable=SC2086
./node_modules/.bin/eslint $files
