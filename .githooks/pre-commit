#!/usr/bin/env bash
# Executa lint-staged nos arquivos em stage antes de cada commit.
# Garante que código com erros de lint ou fora do padrão de formatação não entre no repositório.

set -e

# Se npx não estiver disponível, deixar o commit passar sem bloquear
if ! command -v npx &> /dev/null; then
  echo "warn pre-commit: npx não encontrado, pulando lint-staged" >&2
  exit 0
fi

npx lint-staged
